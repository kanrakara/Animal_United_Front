  m_Name: EndingTalkData
  m_EditorClassIdentifier: Assembly-CSharp::TalkData
  talks:
  - message: "\u30DA\u30F3\u30DA\u30F3\u300C\u3044\u3084\u3041\u3001\u306A\u3093\u3068\u304B\u5012\u305B\u307E\u3057\u305F\u3067\u3059\u30DA\u30F3\u306D\u300D"
  - message: "\u30C1\u30C3\u30AD\u30F3\u300C\u30B3\u30B3\u30FB\u30FB\u30FB\u3001\u4E0A\u3044\u3063\u305F\u308A\u3001\u4E0B\u3044\u3063\u305F\u308A\u3001\u5FD9\u3057\u3044\u30E4\u30C4\u3060\u3063\u305F\u30B3\u30B3\u300D"
  - message: "\u30CD\u30FC\u30B3\u300C\u3082\u3046\u3059\u3063\u304B\u308A\u5915\u65B9\u30CB\u30E3\u30FC\u3001\u304A\u306A\u304B\u304C\u3078\u3063\u305F\u30CB\u30E3\u30FC\u300D"
  - message: "\u30DA\u30F3\u30DA\u30F3\u300C\u3046\u30FC\u3093\u3001\u307B\u3068\u3093\u3069\u30E1\u30AB\u30B9\u30D1\u30A4\u30C0\u30FC\u306B\u98DF\u3079\u3089\u308C\u3066\u30A8\u30B5\u304C\u306A\u3044\u3067\u3059\u306D\u30FC\u300D"
  - message: "\u30C1\u30C3\u30AD\u30F3\u300C\u3053\u3046\u306A\u3063\u305F\u3089\u3001\u3084\u3063\u3064\u3051\u305F\u30E1\u30AB\u30B9\u30D1\u30A4\u30C0\u30FC\u3067\u3082\u98DF\u3079\u308B\u30B3\u30B3\u304B\uFF1F\u300D"
  - message: "\u30CD\u30FC\u30B3\u300C\u305D\u3082\u305D\u3082\u30E1\u30AB\u3060\u304B\u3089\u98DF\u3079\u3089\u308C\u306A\u3044\u30CB\u30E3\u30FC\u300D"
  - message: "\u3068\u307B\u307B\u30FB\u30FB\u30FB\u305B\u3063\u304B\u304F\u8105\u5A01\u3092\u5012\u3057\u3066\u3082\u3001\u307E\u3060\u307E\u3060\u60A9\u307F\u4E8B\u306F\u3064\u304D\u306A\u3055\u305D\u3046\u306A\u30C8\u30EA\u30AA\u3067\u3057\u305F\u30FB\u30FB\u30FB"
