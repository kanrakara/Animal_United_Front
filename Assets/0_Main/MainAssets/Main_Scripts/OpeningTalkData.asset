  m_Script: {fileID: 11500000, guid: 3df49f2941815de46880a011a8a19b23, type: 3}
  m_Name: OpeningTalkData
  m_EditorClassIdentifier: Assembly-CSharp::TalkData
  talks:
  - message: "\u3068\u3042\u308B\u5C71\u4E2D\u30FB\u30FB\u30FB"
  - message: "\u30CD\u30FC\u30B3\u300C\u3046\u308F\u3041\u3001\u3053\u306E\u30D9\u30BF\u30D9\u30BF\u3057\u305F\u7CF8\u306F\u306A\u3093\u30CB\u30E3\uFF01\uFF1F\u53EF\u611B\u3044\u304A\u3066\u3066\u304C\u6C5A\u308C\u3061\u3083\u3046\u30CB\u30E3\u30FC\uFF01\u300D"
  - message: "\u30DA\u30F3\u30DA\u30F3\u300C\u3080\u3080\u30FB\u30FB\u30FB\u3053\u308C\u306F\u30E1\u30AB\u30B9\u30D1\u30A4\u30C0\u30FC\u306E\u7CF8\u3067\u3059\u30DA\u30F3\u306D\u3002\u30D9\u30BF\u30D9\u30BF\u3057\u3066\u6C17\u6301\u3061\u60AA\u3044\u3067\u3059\u30DA\u30F3\u306D\u3002\u300D"
  - message: "\u30C1\u30C3\u30AD\u30F3\u300C\u30B3\u30C3\u30B3\u30B3\u30C3\u30B3\u2026\u3067\u3082\u3001\u3069\u3053\u304B\u3088\u304F\u307F\u308B\u3068\u30AD\u30EC\u30A4\u306A\u6A21\u69D8\u306B\u307F\u3048\u3066\u304D\u305F\u30B3\u30B3\uFF01\u300D"
  - message: "\u30CD\u30FC\u30B3\u300C\u305D\u3093\u306A\u3053\u3068\u8A00\u3063\u3066\u308B\u5834\u5408\u3058\u3083\u306A\u3044\u30CB\u30E3\u30FC\uFF01\u3053\u306E\u307E\u307E\u3060\u3068\u7CF8\u3060\u3089\u3051\u306B\u306A\u3063\u3066\u3001\u30A8\u30B5\u306B\u3055\u308C\u3061\u3083\u3046\u30CB\u30E3\u30FC\uFF01\u300D"
  - message: "\u30DA\u30F3\u300C\u78BA\u304B\u306B\u65E9\u3081\u306E\u5BFE\u51E6\u304C\u5FC5\u8981\u305D\u3046\u3067\u3059\u30DA\u30F3\u306D\u3002\u3068\u306A\u308B\u3068\u3001\u3053\u306E\u7CF8\u306E\u30CC\u30B7\u3092\u3069\u3046\u306B\u304B\u3059\u308B\u3057\u304B\u306A\u3044\u3067\u3059\u30DA\u30F3\u3002\u300D"
  - message: "\u30DF\u30FC\u30CB\u30E3\u300C\u3082\u3046\uFF01\u3053\u3046\u306A\u3063\u305F\u3089\u4ED5\u65B9\u306A\u3044\u30CB\u30E3\u30FC\u3002\u30AF\u30E2\u3092\u5012\u3057\u306B\u3044\u304F\u3057\u304B\u306A\u3044\u30CB\u30E3\u30FC\uFF01\u300D"
  - message: "\u30C1\u30C3\u30AD\u30F3\u300C\u30B3\u30B3\u30B3\u30B3\u30FB\u30FB\u30FB\u307F\u3093\u306A\u5F37\u529B\u3057\u3066\u5012\u3057\u306B\u3044\u304F\u30B3\u30B3\uFF01\u300D"
  - message: "\u306F\u305F\u3057\u3066\u30C7\u30B3\u30DC\u30B3\u30C8\u30EA\u30AA\u306E\u904B\u547D\u3084\u3044\u304B\u306B\u30FB\u30FB\u30FB"
